#!/usr/bin/env bash
# brk - pinned branch tracker
# https://github.com/alexlazarian/devtools/tree/main/brk

set -euo pipefail

VERSION="1.0.0"

# ── Config ──────────────────────────────────────────────────────────

PINS_FILE=".git/pinned-branches"
BASE_BRANCH="main"

# Override base branch via .brk in repo root or $BRK_BASE_BRANCH env var
load_config() {
  if [ -f ".brk" ]; then
    local val
    val=$(grep -E '^base_branch=' .brk 2>/dev/null | head -1 | cut -d= -f2 | tr -d '[:space:]')
    if [ -n "$val" ]; then BASE_BRANCH="$val"; fi
  fi
  if [ -n "${BRK_BASE_BRANCH:-}" ]; then
    BASE_BRANCH="$BRK_BASE_BRANCH"
  fi
}

# ── Helpers ─────────────────────────────────────────────────────────

ensure_git_repo() {
  if ! git rev-parse --git-dir &>/dev/null; then
    echo "Not a git repository" >&2
    return 1
  fi
}

# Cross-platform sed -i (macOS vs GNU)
sed_inplace() {
  if sed --version 2>/dev/null | grep -q GNU; then
    sed -i "$@"
  else
    sed -i '' "$@"
  fi
}

has_gh() {
  command -v gh &>/dev/null
}

# Find the worktree path for a branch, if any
worktree_for_branch() {
  local branch="$1"
  git worktree list --porcelain 2>/dev/null | awk -v b="refs/heads/$branch" '
    /^worktree /{ wt=substr($0,10) }
    /^branch /{ if (substr($0,8)==b) print wt }
  '
}

# ── Commands ────────────────────────────────────────────────────────

cmd_pin() {
  ensure_git_repo
  local branch="${1:-$(git branch --show-current)}"

  if [ -z "$branch" ]; then
    echo "No branch specified and HEAD is detached" >&2
    return 1
  fi

  if ! git rev-parse --verify "$branch" &>/dev/null; then
    echo "Branch not found: $branch" >&2
    return 1
  fi

  if [ -f "$PINS_FILE" ] && grep -qx "$branch" "$PINS_FILE"; then
    echo "Already pinned: $branch"
    return 0
  fi

  echo "$branch" >> "$PINS_FILE"
  echo "Pinned: $branch"
}

cmd_unpin() {
  ensure_git_repo
  local branch="${1:-$(git branch --show-current)}"

  if [ -z "$branch" ]; then
    echo "No branch specified and HEAD is detached" >&2
    return 1
  fi

  if [ ! -f "$PINS_FILE" ]; then
    echo "No pinned branches" >&2
    return 1
  fi

  if ! grep -qx "$branch" "$PINS_FILE"; then
    echo "Not pinned: $branch" >&2
    return 1
  fi

  sed_inplace "/^${branch//\//\\/}$/d" "$PINS_FILE"
  echo "Unpinned: $branch"
}

cmd_status() {
  ensure_git_repo

  if [ ! -f "$PINS_FILE" ] || [ ! -s "$PINS_FILE" ]; then
    echo "No pinned branches. Use 'brk pin <branch>' to add one."
    return 0
  fi

  git fetch origin --quiet 2>/dev/null || true

  local current
  current=$(git branch --show-current 2>/dev/null || echo "")

  printf "\n"
  printf "  \033[1m%-48s %8s %8s   %-20s\033[0m\n" "BRANCH" "BEHIND" "AHEAD" "PR"
  printf "  %-48s %8s %8s   %-20s\n" "------------------------------------------------" "--------" "--------" "--------------------"

  while IFS= read -r branch; do
    [ -z "$branch" ] && continue

    local marker="  "
    if [ "$branch" = "$current" ]; then
      marker="* "
    fi

    local behind ahead
    behind=$(git rev-list --count "$branch..origin/$BASE_BRANCH" 2>/dev/null || echo "?")
    ahead=$(git rev-list --count "origin/$BASE_BRANCH..$branch" 2>/dev/null || echo "?")

    local behind_display
    if [ "$behind" = "0" ]; then
      behind_display="\033[32m✓\033[0m"
    elif [ "$behind" = "?" ]; then
      behind_display="\033[90m?\033[0m"
    else
      behind_display="\033[33m↓ $behind\033[0m"
    fi

    local ahead_display
    if [ "$ahead" = "0" ]; then
      ahead_display="\033[90m-\033[0m"
    elif [ "$ahead" = "?" ]; then
      ahead_display="\033[90m?\033[0m"
    else
      ahead_display="\033[36m↑ $ahead\033[0m"
    fi

    local pr_info=""
    if has_gh; then
      pr_info=$(gh pr list --head "$branch" --json number,state,isDraft \
        --jq '.[0] | "#\(.number) \(if .isDraft then "(draft)" elif .state == "MERGED" then "(merged)" elif .state == "CLOSED" then "(closed)" else "(open)" end)"' 2>/dev/null || echo "")
    fi
    [ -z "$pr_info" ] && pr_info="\033[90m-\033[0m"

    printf "${marker}%-48s %8b %8b   %-20b\n" "$branch" "$behind_display" "$ahead_display" "$pr_info"
  done < "$PINS_FILE"

  printf "\n"
}

cmd_list() {
  ensure_git_repo
  if [ ! -f "$PINS_FILE" ] || [ ! -s "$PINS_FILE" ]; then
    echo "No pinned branches."
    return 0
  fi
  cat "$PINS_FILE"
}

sync_branch() {
  local branch="$1"
  local strategy="$2"

  local behind
  behind=$(git rev-list --count "$branch..origin/$BASE_BRANCH" 2>/dev/null || echo "0")
  if [ "$behind" = "0" ]; then
    printf "  \033[32m✓\033[0m %s already up to date\n" "$branch"
    return 0
  fi

  local current
  current=$(git branch --show-current 2>/dev/null || echo "")

  local wt_path
  wt_path=$(worktree_for_branch "$branch")

  if [ "$strategy" = "rebase" ]; then
    printf "  ↻ rebasing %s (%s behind)..." "$branch" "$behind"
    if git rebase origin/"$BASE_BRANCH" "$branch" --quiet 2>/dev/null; then
      printf " \033[32mdone\033[0m\n"
      [ "$(git branch --show-current 2>/dev/null)" != "$current" ] && git switch "$current" --quiet 2>/dev/null
    else
      printf " \033[31mconflict - aborting\033[0m\n"
      git rebase --abort 2>/dev/null
      [ "$(git branch --show-current 2>/dev/null)" != "$current" ] && git switch "$current" --quiet 2>/dev/null
      return 1
    fi
  else
    printf "  ↻ merging %s into %s (%s behind)..." "$BASE_BRANCH" "$branch" "$behind"

    if [ -n "$wt_path" ] && [ "$branch" != "$current" ]; then
      if git -C "$wt_path" merge origin/"$BASE_BRANCH" --quiet --no-edit 2>/dev/null; then
        printf " \033[32mdone\033[0m (via worktree)\n"
      else
        printf " \033[31mconflict - aborting\033[0m\n"
        git -C "$wt_path" merge --abort 2>/dev/null
        return 1
      fi
    elif [ "$branch" = "$current" ]; then
      if git merge origin/"$BASE_BRANCH" --quiet --no-edit 2>/dev/null; then
        printf " \033[32mdone\033[0m\n"
      else
        printf " \033[31mconflict - aborting\033[0m\n"
        git merge --abort 2>/dev/null
        return 1
      fi
    else
      git switch "$branch" --quiet 2>/dev/null
      if git merge origin/"$BASE_BRANCH" --quiet --no-edit 2>/dev/null; then
        printf " \033[32mdone\033[0m\n"
      else
        printf " \033[31mconflict - aborting\033[0m\n"
        git merge --abort 2>/dev/null
      fi
      git switch "$current" --quiet 2>/dev/null
    fi
  fi
}

cmd_sync() {
  ensure_git_repo

  if [ ! -f "$PINS_FILE" ] || [ ! -s "$PINS_FILE" ]; then
    echo "No pinned branches."
    return 0
  fi

  local default_strategy="${1:-}"

  printf "Fetching origin...\n"
  git fetch origin --quiet 2>/dev/null || true
  printf "\n"

  local branches=()
  while IFS= read -r b; do
    [ -n "$b" ] && branches+=("$b")
  done < "$PINS_FILE"

  for branch in "${branches[@]}"; do
    local behind
    behind=$(git rev-list --count "$branch..origin/$BASE_BRANCH" 2>/dev/null || echo "0")

    if [ "$behind" = "0" ]; then
      printf "  \033[32m✓\033[0m %s already up to date\n" "$branch"
      continue
    fi

    local strategy="$default_strategy"
    if [ -z "$strategy" ]; then
      printf "  %s (\033[33m%s behind\033[0m) [m]erge / [r]ebase / [s]kip? " "$branch" "$behind"
      read -r choice
      case "$choice" in
        m|merge)  strategy="merge" ;;
        r|rebase) strategy="rebase" ;;
        s|skip|"")
          printf "  \033[90m  skipped\033[0m\n"
          continue
          ;;
        *)
          printf "  \033[90m  skipped (unknown choice)\033[0m\n"
          continue
          ;;
      esac
    else
      strategy="${strategy#--}"
    fi

    sync_branch "$branch" "$strategy"
  done

  printf "\n"
}

cmd_live() {
  local interval="${1:-3}"

  trap 'printf "\033[?1049l"; tput cnorm; exit 0' INT TERM
  tput civis
  printf '\033[?1049h'

  while true; do
    tput home
    tput ed
    printf "  \033[90m● live  refreshing every %ss  (Ctrl+C to exit)\033[0m\n" "$interval"
    cmd_status
    sleep "$interval"
  done
}

# ── Main ────────────────────────────────────────────────────────────

load_config

case "${1:-status}" in
  pin)       cmd_pin "${2:-}" ;;
  unpin|rm)  cmd_unpin "${2:-}" ;;
  sync)      cmd_sync "${2:-}" ;;
  status|s)  cmd_status ;;
  live|watch) cmd_live "${2:-3}" ;;
  list|ls)   cmd_list ;;
  -v|--version|version)
    echo "brk $VERSION"
    ;;
  -h|--help|help)
    cat <<'HELP'
brk - pinned branch tracker

Usage:
  brk                   show status of all pinned branches
  brk pin [branch]      pin a branch (defaults to current)
  brk unpin [branch]    unpin a branch
  brk sync              sync pinned branches (asks per branch)
  brk sync --merge      merge base branch into all pinned branches
  brk sync --rebase     rebase all pinned branches onto base branch
  brk live [seconds]    live-updating dashboard (default: 3s)
  brk list              list pinned branch names
  brk version           show version
  brk help              show this help

Config:
  Base branch defaults to "main". Override with:
    - .brk file in repo root:  base_branch=develop
    - Environment variable:    BRK_BASE_BRANCH=develop

Dependencies:
  - git (required)
  - gh  (optional, for PR status column)
HELP
    ;;
  *)
    echo "Unknown command: $1 (try 'brk help')" >&2
    exit 1
    ;;
esac
